{
	"name": "@bruhabruh/type-safe",
	"type": "module",
	"version": "1.3.0",
	"description": "BruhaBruh Type Safe Library for TypeScript",
	"author": "BruhaBruh",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/bruhabruh/type-safe"
	},
	"keywords": [],
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc && vite build",
		"lint": "eslint . --report-unused-disable-directives",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"prepare": "husky"
	},
	"dependencies": {
		"type-fest": "^5.4.4"
	},
	"optionalDependencies": {
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^7.4.3",
		"@bruhabruh/tsconfig": "^1.0.4",
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"@commitlint/types": "^20.4.0",
		"@types/node": "^25.2.3",
		"eslint": "^10.0.0",
		"eslint-plugin-format": "^1.4.0",
		"glob": "^13.0.4",
		"husky": "^9.1.7",
		"nano-staged": "^0.9.0",
		"rollup-plugin-preserve-directives": "^0.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.0.18"
	},
	"nano-staged": {
		"*.{js,ts,md,yaml,yml,json}": [
			"eslint --fix --quiet --report-unused-disable-directives"
		]
	}
}
